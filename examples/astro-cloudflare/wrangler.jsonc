{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "lucid-astro-cloudflare-example",
	// Source-side worker entry generated by the Lucid Astro integration.
	// After `astro build`, Wrangler is redirected via `.wrangler/deploy/config.json`
	// to Astro's generated deploy config in `dist/server/wrangler.json`.
	"main": "./.lucid/astro/worker.ts",
	"compatibility_date": "2026-04-17",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "CLOUDFLARE_KV",
			"id": "33f2f137d7a7448397f9d8ed0faec853"
		}
	],
	"queues": {
		"producers": [
			{
				"binding": "CLOUDFLARE_QUEUES",
				"queue": "lucid-astro-cloudflare-example-queue"
			}
		],
		"consumers": [
			{
				"queue": "lucid-astro-cloudflare-example-queue",
				"max_batch_size": 10,
				"max_batch_timeout": 30,
				"max_retries": 3
			}
		]
	}
}
