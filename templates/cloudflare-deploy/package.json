{
	"name": "lucid-cloudflare",
	"private": true,
	"description": "Lucid CMS Cloudflare starter",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"dev": "lucidcms dev",
		"serve": "lucidcms serve",
		"build": "lucidcms build",
		"typegen": "lucidcms typegen",
		"sync": "lucidcms sync",
		"migrate": "lucidcms migrate",
		"migrate:new": "lucidcms migrate:new",
		"migrate:status": "lucidcms migrate:status",
		"migrate:rollback": "lucidcms migrate:rollback",
		"migrate:reset": "lucidcms migrate:reset",
		"migrate:fresh": "lucidcms migrate:fresh",
		"deploy": "npm run deploy:database && wrangler deploy",
		"deploy:database": "lucidcms migrate --force --remote",
		"wrangler:dev": "lucidcms build --silent && wrangler dev --test-scheduled",
		"wrangler:deploy": "npm run build && npm run deploy"
	},
	"dependencies": {
		"@lucidcms/core": "0.14.0-alpha.0",
		"@lucidcms/db-d1": "0.1.1",
		"@lucidcms/plugin-cloudflare-kv": "1.0.1",
		"@lucidcms/plugin-cloudflare-r2": "1.0.1",
		"@lucidcms/plugin-pages": "0.4.1",
		"@lucidcms/runtime-cloudflare": "1.0.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260623.1",
		"typescript": "^6.0.3",
		"wrangler": "^4.104.0"
	},
	"cloudflare": {
		"bindings": {
			"LUCID_SECRET": {
				"description": "Generate a stable 64 character hex secret with `openssl rand -hex 32`. Keep this value safe; changing it invalidates existing sessions and encrypted Lucid data."
			}
		}
	},
	"engines": {
		"node": "^24.0.0"
	},
	"author": "Build Lucid Ltd"
}
