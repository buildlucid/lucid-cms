{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"resolveJsonModule": true,
		"target": "ESNext",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"],
		"outDir": "dist"
	},
	"include": ["lucid.config.ts", "src/**/*"],
	"exclude": ["node_modules"]
}
