---
import { getAllPages } from "../../lib/lucid-pages.js";

export const prerender = true;

export async function getStaticPaths() {
	const pages = await getAllPages();

	return pages.map((page) => ({
		params: {
			slug: page.fullSlug === "/" ? undefined : page.fullSlug.slice(1),
		},
		props: {
			page,
		},
	}));
}

const { page } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{page.title} | Static Lucid Route</title>
		<style>
			:root {
				font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
				background:
					radial-gradient(circle at top left, rgba(255, 173, 96, 0.35), transparent 30%),
					linear-gradient(180deg, #fff9ef 0%, #f4efe5 100%);
				color: #14253f;
			}

			body {
				margin: 0;
				min-height: 100vh;
				padding: 2rem;
			}

			main {
				max-width: 48rem;
				margin: 0 auto;
				padding: 2rem;
				border-radius: 1.5rem;
				background: rgba(255, 255, 255, 0.8);
				box-shadow: 0 24px 80px rgba(20, 37, 63, 0.12);
			}

			eyebrow {
				display: inline-flex;
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				background: rgba(20, 37, 63, 0.08);
				font-size: 0.78rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			h1 {
				margin: 1rem 0 0.75rem;
				font-family: "IBM Plex Serif", Georgia, serif;
				font-size: clamp(2rem, 4vw, 3rem);
			}

			p {
				line-height: 1.7;
				margin: 0.75rem 0 0;
			}

			figure {
				margin: 1.5rem 0 0;
			}

			img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 1rem;
				box-shadow: 0 16px 48px rgba(20, 37, 63, 0.14);
			}

			article {
				margin-top: 1.5rem;
			}

			article :global(p),
			article :global(li),
			article :global(blockquote) {
				line-height: 1.7;
			}

			article :global(h2),
			article :global(h3),
			article :global(h4) {
				font-family: "IBM Plex Serif", Georgia, serif;
				margin: 1.5rem 0 0.5rem;
			}

			code,
			a {
				color: #8b3d12;
			}
		</style>
	</head>
	<body>
		<main>
			<eyebrow>Static Lucid Client Route</eyebrow>
			<h1>{page.title}</h1>
			{
				page.thumbnail && (
					<figure>
						<img
							src={page.thumbnail.url}
							alt={page.thumbnail.alt}
							width={page.thumbnail.width ?? undefined}
							height={page.thumbnail.height ?? undefined}
							loading="eager"
						/>
					</figure>
				)
			}
			<article set:html={page.bodyHtml}></article>
			<p>Lucid full slug: <code>{page.fullSlug}</code></p>
			<p><a href={`/server${page.fullSlug}`}>View the server-rendered version</a></p>
		</main>
	</body>
</html>
