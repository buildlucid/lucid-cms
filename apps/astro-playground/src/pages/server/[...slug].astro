---
import { getPageByFullSlug } from "../../lib/lucid-pages.js";

export const prerender = false;

const fullSlug = Astro.params.slug ? `/${Astro.params.slug}` : "/";
const page = await getPageByFullSlug(fullSlug);

if (!page) {
	Astro.response.status = 404;
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>
			{page ? `${page.title} | Server Lucid Route` : "Page Not Found | Server Lucid Route"}
		</title>
		<style>
			:root {
				font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
				background:
					radial-gradient(circle at top right, rgba(97, 177, 255, 0.24), transparent 34%),
					linear-gradient(180deg, #f7fbff 0%, #edf4ff 100%);
				color: #10213d;
			}

			body {
				margin: 0;
				min-height: 100vh;
				padding: 2rem;
			}

			main {
				max-width: 48rem;
				margin: 0 auto;
				padding: 2rem;
				border-radius: 1.5rem;
				background: rgba(255, 255, 255, 0.8);
				box-shadow: 0 24px 80px rgba(16, 33, 61, 0.12);
			}

			eyebrow {
				display: inline-flex;
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				background: rgba(16, 33, 61, 0.08);
				font-size: 0.78rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			h1 {
				margin: 1rem 0 0.75rem;
				font-family: "IBM Plex Serif", Georgia, serif;
				font-size: clamp(2rem, 4vw, 3rem);
			}

			p {
				line-height: 1.7;
				margin: 0.75rem 0 0;
			}

			code,
			a {
				color: #1e5ca8;
			}
		</style>
	</head>
	<body>
		<main>
			{
				page ? (
					<>
						<eyebrow>Server Lucid Client Route</eyebrow>
						<h1>{page.title}</h1>
						<p>{page.body}</p>
						<p>Lucid full slug: <code>{page.fullSlug}</code></p>
						<p>
							<a href={`/static${page.fullSlug}`}>View the prerendered version</a>
						</p>
					</>
				) : (
					<>
						<eyebrow>Server Lucid Client Route</eyebrow>
						<h1>Lucid page not found</h1>
						<p>
							No page matched <code>{fullSlug}</code> when the Astro route queried the
							Lucid client document endpoint with <code>filter[_fullSlug]</code>.
						</p>
					</>
				)
			}
		</main>
	</body>
</html>
