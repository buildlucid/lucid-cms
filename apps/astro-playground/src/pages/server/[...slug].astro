---
import getToolkit from "@lucidcms/astro/toolkit";
import PageCollection from "../../lucid/collections/pages";

export const prerender = false;

const fullSlug = Astro.params.slug ? `/${Astro.params.slug}` : "/";
const toolkit = await getToolkit();
const response = await toolkit.documents.getSingle({
	collectionKey: PageCollection.key,
	status: "latest",
	query: {
		filter: {
			_fullSlug: {
				value: fullSlug,
			},
		},
	},
});

if (response.error && response.error.status !== 404) {
	throw new Error(response.error.message ?? "Failed to load the page.");
}

const page = response.error ? null : response.data;

if (!page) {
	Astro.response.status = 404;
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>
			{page
				? `${page.fields?.page_title?.translations?.en || "Untitled page"} | Server Lucid Route`
				: "Page Not Found | Server Lucid Route"}
		</title>
		<style>
			:root {
				font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
				background:
					radial-gradient(circle at top right, rgba(97, 177, 255, 0.24), transparent 34%),
					linear-gradient(180deg, #f7fbff 0%, #edf4ff 100%);
				color: #10213d;
			}

			body {
				margin: 0;
				min-height: 100vh;
				padding: 2rem;
			}

			main {
				max-width: 48rem;
				margin: 0 auto;
				padding: 2rem;
				border-radius: 1.5rem;
				background: rgba(255, 255, 255, 0.8);
				box-shadow: 0 24px 80px rgba(16, 33, 61, 0.12);
			}

			eyebrow {
				display: inline-flex;
				padding: 0.35rem 0.7rem;
				border-radius: 999px;
				background: rgba(16, 33, 61, 0.08);
				font-size: 0.78rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			h1 {
				margin: 1rem 0 0.75rem;
				font-family: "IBM Plex Serif", Georgia, serif;
				font-size: clamp(2rem, 4vw, 3rem);
			}

			p {
				line-height: 1.7;
				margin: 0.75rem 0 0;
			}

			figure {
				margin: 1.5rem 0 0;
			}

			img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 1rem;
				box-shadow: 0 16px 48px rgba(16, 33, 61, 0.14);
			}

			article {
				margin-top: 1.5rem;
			}

			article :global(p),
			article :global(li),
			article :global(blockquote) {
				line-height: 1.7;
			}

			article :global(h2),
			article :global(h3),
			article :global(h4) {
				font-family: "IBM Plex Serif", Georgia, serif;
				margin: 1.5rem 0 0.5rem;
			}

			code,
			a {
				color: #1e5ca8;
			}
		</style>
	</head>
	<body>
		<main>
			{
				page ? (
					<>
						<eyebrow>Server Lucid Client Route</eyebrow>
						<h1>{page.fields?.page_title?.translations?.en || "Untitled page"}</h1>
						<p>
							Lucid full slug: <code>{page.fields?.fullSlug?.translations?.en || fullSlug}</code>
						</p>
						<p>
							<a href={`/static${page.fields?.fullSlug?.translations?.en || fullSlug}`}>
								View the prerendered version
							</a>
						</p>
					</>
				) : (
					<>
						<eyebrow>Server Lucid Client Route</eyebrow>
						<h1>Lucid page not found</h1>
						<p>
							No page matched <code>{fullSlug}</code> when the Astro route queried
							the Lucid client document endpoint with <code>filter[_fullSlug]</code>.
						</p>
					</>
				)
			}
		</main>
	</body>
</html>
