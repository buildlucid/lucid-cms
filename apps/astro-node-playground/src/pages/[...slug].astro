---
import { setAdminBar } from "@lucidcms/astro/admin-bar";
import { asDocument } from "@lucidcms/client";
import "../index.css";
import getPage from "../helpers/get-page";

export const prerender = false;
const previewToken = Astro.url.searchParams.get("preview") ?? undefined;
const fullSlug = Astro.params.slug ? `/${Astro.params.slug}` : "/";

if (previewToken) {
	//* preview tokens are bearer credentials: do not cache or forward this URL.
	Astro.response.headers.set("Cache-Control", "private, no-store");
	Astro.response.headers.set("Referrer-Policy", "no-referrer");
}

const pageResponse = await getPage({ fullSlug, previewToken });

if (previewToken && pageResponse.error) {
	Astro.response.status = pageResponse.error.status ?? 401;
}

const page = asDocument(pageResponse.data);

if (page) {
	setAdminBar(Astro, {
		edit: {
			collectionKey: page.collectionKey,
			documentId: page.id,
		},
	});
}

const title = page?.field("title").value();
const summary = page?.field("summary").value();
const pageFullSlug = page?.field("fullSlug").value();
const slug = page?.field("slug").value();

const previewError = previewToken ? pageResponse.error : undefined;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		{previewToken && <meta name="referrer" content="no-referrer" />}
		<title>
			{title
				? `${title} | Lucid CMS`
				: "Lucid CMS"}
		</title>
	</head>
	<body>
		<main class="page-shell">
			<div class="page-backdrop">
				<div class="page-frame">
					<header class="page-header">
						<a class="brand" href="/" aria-label="Lucid CMS">
							<img
								class="brand-logo"
								src="/text-logo-dark.svg"
								alt=""
							/>
						</a>

						<nav class="page-nav" aria-label="Primary">
							<a
								class="nav-link"
								href="https://lucidcms.io/en/cms/docs/getting-started/what-is-lucid-cms/"
							>
								Docs
							</a>
							<a class="nav-link" href="/lucid">Admin</a>
						</nav>
					</header>

					<section class="welcome-card">
						<p class="eyebrow">Astro + Node</p>
						<h1 class="welcome-title">
							{previewError
								? "This preview link is unavailable."
								: page
									? "Your Lucid page is live."
									: "Create your first Lucid page."}
						</h1>
						<p class="welcome-copy">
							{previewError ? (
								<>The preview link is invalid or has expired. Create a new one in Lucid.</>
							) : page ? (
								<>
									This route is rendering your <code>page</code> document from
									<code>{pageFullSlug || "/"}</code>. Update it in Lucid and refresh
									to see the latest content here.
								</>
							) : (
								<>
									Open the Lucid admin, create a <code>page</code> document with
									the full slug <code>/</code>, then refresh this route to see
									your content appear here.
								</>
							)}
						</p>

						<div class="welcome-actions">
							<a class="button button-primary" href="/lucid">Open Lucid</a>
							<a
								class="button"
								href="https://lucidcms.io/en/cms/docs/getting-started/what-is-lucid-cms/"
							>
								Getting started
							</a>
						</div>
					</section>

					{page && (
						<section class="content-card">
							<div class="document-panel">
								<div class="document-row">
									<span class="document-label">Title</span>
									<p class="document-value">
										{title || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Summary</span>
									<p class="document-value">
										{summary || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Slug</span>
									<p class="document-value">
										{slug || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Full slug</span>
									<p class="document-value">
										{pageFullSlug || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Brick fields</span>
									<p class="document-value">
										{page.bricks().reduce(
											(count, brick) =>
												count + Object.keys(brick.raw.fields ?? {}).length,
											0,
										)}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Created</span>
									<p class="document-value">
										{page.raw.createdAt
											? new Date(page.raw.createdAt).toLocaleString("en-GB", {
													dateStyle: "medium",
													timeStyle: "short",
												})
											: "Not available"}
									</p>
								</div>
							</div>
						</section>
					)}
				</div>
			</div>
		</main>
	</body>
</html>
