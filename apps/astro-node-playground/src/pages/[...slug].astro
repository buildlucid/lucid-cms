---
import { asDocument } from "@lucidcms/client";
import "../index.css";
import getPage from "../services/pages";

export const prerender = false;

const result = await getPage({
	fullSlug: Astro.params.slug ? `/${Astro.params.slug}` : "/",
	astro: Astro,
});

if (result.preview.error) {
	Astro.response.status = result.preview.error.status ?? 401;
} else if (result.page.error) {
	Astro.response.status = result.page.error.status ?? 404;
}

const page = asDocument(result.page.data);
const preview = result.preview.data;

const title = page?.field("title").value();
const summary = page?.field("summary").value();
const pageFullSlug = page?.field("fullSlug").value();
const slug = page?.field("slug").value();

const previewError =
	result.preview.error ?? (preview?.active ? result.page.error : undefined);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		{(preview?.active || previewError) && (
			<meta name="referrer" content="no-referrer" />
		)}
		{preview?.active && preview.token && <meta name="lucid-preview" content={preview.token} />}
		{preview?.preview && <meta name="lucid-preview-mode" content={preview.preview.mode} />}
		<title>
			{title
				? `${title} | Lucid CMS`
				: "Lucid CMS"}
		</title>
	</head>
	<body
		data-lucid-edit-collection={page?.collectionKey}
		data-lucid-edit-document={page?.id}
		data-lucid-edit-status={page?.status}
		data-lucid-edit-version={page?.meta?.versionId}
	>
		<main class="page-shell">
			<div class="page-backdrop">
				<div class="page-frame">
					<header class="page-header">
						<a class="brand" href="/" aria-label="Lucid CMS">
							<img
								class="brand-logo"
								src="/text-logo-dark.svg"
								alt=""
							/>
						</a>

						<nav class="page-nav" aria-label="Primary">
							<a class="nav-link" href="/">Home</a>
							<a class="nav-link" href="/about">About</a>
							<a
								class="nav-link"
								href="https://lucidcms.io/en/cms/docs/getting-started/what-is-lucid-cms/"
							>
								Docs
							</a>
							<a class="nav-link" href="/lucid">Admin</a>
						</nav>
					</header>

					<section class="welcome-card">
						<p class="eyebrow">Astro + Node</p>
						<h1 class="welcome-title">
							{previewError
								? "This preview link is unavailable."
								: page
									? "Your Lucid page is live."
									: "Create your first Lucid page."}
						</h1>
						<p class="welcome-copy">
							{previewError ? (
								<>The preview link is invalid or has expired. Create a new one in Lucid.</>
							) : page ? (
								<>
									This route is rendering your <code>page</code> document from
									<code>{pageFullSlug || "/"}</code>. Update it in Lucid and refresh
									to see the latest content here.
								</>
							) : (
								<>
									Open the Lucid admin, create a <code>page</code> document with
									the full slug <code>/</code>, then refresh this route to see
									your content appear here.
								</>
							)}
						</p>

						<div class="welcome-actions">
							<a class="button button-primary" href="/lucid">Open Lucid</a>
							<a
								class="button"
								href="https://lucidcms.io/en/cms/docs/getting-started/what-is-lucid-cms/"
							>
								Getting started
							</a>
						</div>
					</section>

					{page && (
						<section class="content-card">
							<div class="document-panel">
								<div class="document-row">
									<span class="document-label">Title</span>
									<p class="document-value">
										{title || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Summary</span>
									<p class="document-value">
										{summary || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Slug</span>
									<p class="document-value">
										{slug || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Full slug</span>
									<p class="document-value">
										{pageFullSlug || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Brick fields</span>
									<p class="document-value">
										{page.bricks().reduce(
											(count, brick) =>
												count + Object.keys(brick.raw.fields ?? {}).length,
											0,
										)}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Created</span>
									<p class="document-value">
										{page.raw.createdAt
											? new Date(page.raw.createdAt).toLocaleString("en-GB", {
													dateStyle: "medium",
													timeStyle: "short",
												})
											: "Not available"}
									</p>
								</div>
							</div>
						</section>
					)}
				</div>
			</div>
		</main>
		<script src="../scripts/toolbar.ts"></script>
	</body>
</html>
