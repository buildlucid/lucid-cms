{
	"name": "@lucidcms/cloudflare-playground",
	"private": true,
	"description": "Internal Cloudflare playground used for Lucid CMS testing.",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"dev": "lucidcms dev",
		"serve": "lucidcms serve",
		"build": "lucidcms build",
		"typegen": "lucidcms typegen",
		"sync": "lucidcms sync",
		"migrate": "lucidcms migrate",
		"migrate:new": "lucidcms migrate:new",
		"migrate:status": "lucidcms migrate:status",
		"migrate:rollback": "lucidcms migrate:rollback",
		"migrate:reset": "lucidcms migrate:reset",
		"migrate:fresh": "lucidcms migrate:fresh",
		"wrangler:dev": "lucidcms build --silent && wrangler dev --test-scheduled",
		"wrangler:deploy": "npm run build && wrangler deploy"
	},
	"dependencies": {
		"@lucidcms/runtime-cloudflare": "*",
		"@lucidcms/core": "*",
		"@lucidcms/db-d1": "*",
		"@lucidcms/plugin-cloudflare-kv": "*",
		"@lucidcms/plugin-cloudflare-r2": "*",
		"@lucidcms/plugin-pages": "*"
	},
	"author": "Build Lucid Ltd",
	"license": "MIT",
	"devDependencies": {
		"typescript": "^6.0.3",
		"wrangler": "^4.104.0"
	},
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	}
}
