---
import getToolkit from "@lucidcms/astro/toolkit";
import { asDocument } from "@lucidcms/client";
import "../index.css";

export const prerender = false;
const toolkit = await getToolkit();

const response = await toolkit.documents.getSingle({
	collectionKey: "page",
	status: "latest",
	query: {
		filter: {
			_fullSlug: {
				value: Astro.params.slug ? `/${Astro.params.slug}` : "/",
			},
		},
		include: ["bricks", "refs"],
	},
});

// if (response.error) {
// 	return Astro.redirect("/404");
// }

const page = asDocument(response.data);

const title = page?.field("title").value();
const summary = page?.field("summary").value();
const fullSlug = page?.field("fullSlug").value();
const slug = page?.field("slug").value();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>
			{title
				? `${title} | Lucid CMS`
				: "Lucid CMS"}
		</title>
	</head>
	<body
		data-lucid-edit-collection={page?.collectionKey}
		data-lucid-edit-document={page?.id}
		data-lucid-edit-status={page?.status}
		data-lucid-edit-version={page?.meta?.versionId}
	>
		<main class="page-shell">
			<div class="page-backdrop">
				<div class="page-frame">
					<header class="page-header">
						<a class="brand" href="/" aria-label="Lucid CMS">
							<img
								class="brand-logo"
								src="/text-logo-dark.svg"
								alt=""
							/>
						</a>

						<nav class="page-nav" aria-label="Primary">
							<a
								class="nav-link"
								href="https://lucidcms.io/en/cms/docs/getting-started/what-is-lucid-cms/"
							>
								Docs
							</a>
							<a class="nav-link" href="/lucid">Admin</a>
						</nav>
					</header>

					<section class="welcome-card">
						<p class="eyebrow">Astro + Cloudflare</p>
						<h1 class="welcome-title">
							{page ? "Your Lucid page is live." : "Create your first Lucid page."}
						</h1>
						<p class="welcome-copy">
							{page ? (
								<>
									This route is rendering your <code>page</code> document from
									<code>{fullSlug || "/"}</code>. Update it in
									Lucid and refresh to see the latest content here.
								</>
							) : (
								<>
									Open the Lucid admin, create a <code>page</code> document with
									the full slug <code>/</code>, then refresh this route to see
									your content appear here.
								</>
							)}
						</p>

						<div class="welcome-actions">
							<a class="button button-primary" href="/lucid">Open Lucid</a>
							<a
								class="button"
								href="https://lucidcms.io/en/cms/docs/getting-started/what-is-lucid-cms/"
							>
								Getting started
							</a>
						</div>
					</section>

					{page && (
						<section class="content-card">
							<div class="document-panel">
								<div class="document-row">
									<span class="document-label">Title</span>
									<p class="document-value">
										{title || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Summary</span>
									<p class="document-value">
										{summary || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Slug</span>
									<p class="document-value">
										{slug || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Full slug</span>
									<p class="document-value">
										{fullSlug || "Not set"}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Brick fields</span>
									<p class="document-value">
										{page.bricks().reduce(
											(count, brick) =>
												count + Object.keys(brick.raw.fields ?? {}).length,
											0,
										) ?? 0}
									</p>
								</div>

								<div class="document-row">
									<span class="document-label">Created</span>
									<p class="document-value">
										{page?.raw.createdAt
											? new Date(page.raw.createdAt).toLocaleString("en-GB", {
													dateStyle: "medium",
													timeStyle: "short",
												})
											: "Not available"}
									</p>
								</div>
							</div>
						</section>
					)}
				</div>
			</div>
		</main>
		<script src="../scripts/toolbar.ts"></script>
	</body>
</html>
