{
	"name": "@lucidcms/types",
	"version": "0.1.0",
	"private": false,
	"description": "Shared public TypeScript types for Lucid CMS packages.",
	"type": "module",
	"types": "./dist/index.d.ts",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src"
	},
	"files": [
		"dist"
	],
	"author": "Lucid",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/types"
	},
	"keywords": [
		"CMS",
		"Lucid CMS",
		"Lucid",
		"Types",
		"TypeScript"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3"
	},
	"sideEffects": false,
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	},
	"license": "MIT"
}
