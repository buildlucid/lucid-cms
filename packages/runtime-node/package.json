{
	"name": "@lucidcms/runtime-node",
	"version": "1.0.1",
	"private": false,
	"description": "The official Node runtime for Lucid CMS",
	"type": "module",
	"types": "./dist/index.d.mts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./runtime": {
			"types": "./dist/runtime.d.mts",
			"default": "./dist/runtime.mjs"
		},
		"./types": {
			"types": "./dist/types.d.mts",
			"default": "./dist/types.mjs"
		}
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src"
	},
	"files": [
		"dist"
	],
	"author": "Build Lucid Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/runtime-node"
	},
	"keywords": [
		"CMS",
		"Lucid CMS",
		"Lucid",
		"Node",
		"Runtime"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@lucidcms/core": "0.14.0-alpha.0",
		"@types/node": "^24.13.2",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.6",
		"@types/node-cron": "^3.0.11",
		"dotenv": "^17.4.2",
		"rolldown": "^1.1.2",
		"rollup-plugin-node-externals": "^9.0.1",
		"node-cron": "^4.5.0"
	},
	"peerDependencies": {
		"@lucidcms/core": "^0.14.0-alpha.0",
		"hono": "^4.12.27",
		"hono-openapi": "^1.3.0"
	},
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	}
}
