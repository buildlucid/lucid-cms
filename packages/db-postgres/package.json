{
	"name": "@lucidcms/db-postgres",
	"version": "1.0.2",
	"private": false,
	"description": "The official Postgres database adapter for Lucid CMS",
	"type": "module",
	"types": "./dist/index.d.ts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.ts"
		},
		"./types": {
			"import": "./dist/types.mjs",
			"types": "./dist/types.d.ts"
		}
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src"
	},
	"files": [
		"dist"
	],
	"author": "Build Lucid Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/db-postgres"
	},
	"keywords": [
		"CMS",
		"Lucid CMS",
		"Lucid",
		"Postgres",
		"Database Adapter"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@lucidcms/core": "0.15.0-alpha.0",
		"@types/node": "^24.13.2",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"kysely": "0.29.2",
		"kysely-postgres-js": "^3.0.0",
		"postgres": "^3.4.9"
	},
	"peerDependencies": {
		"@lucidcms/core": "^0.15.0-alpha.0"
	},
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	}
}
