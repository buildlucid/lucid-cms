{
	"name": "@lucidcms/astro",
	"version": "0.12.0-alpha.1",
	"private": false,
	"description": "The official Astro integration for Lucid CMS",
	"type": "module",
	"types": "./dist/index.d.mts",
	"module": "./dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./define-config": {
			"types": "./dist/define-config.d.mts",
			"default": "./dist/define-config.mjs"
		},
		"./runtime": {
			"types": "./dist/runtime.d.mts",
			"default": "./dist/runtime.mjs"
		},
		"./types": {
			"types": "./dist/types.d.mts",
			"default": "./dist/types.mjs"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src"
	},
	"files": [
		"dist"
	],
	"author": "Lucid",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/astro"
	},
	"keywords": [
		"CMS",
		"Astro",
		"Lucid CMS",
		"Lucid",
		"Integration"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@lucidcms/cloudflare-adapter": "*",
		"@lucidcms/config": "*",
		"@lucidcms/core": "*",
		"@lucidcms/node-adapter": "*",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^24.10.4",
		"astro": "^6.1.6",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"mime-types": "^3.0.2"
	},
	"peerDependencies": {
		"@lucidcms/cloudflare-adapter": "^1.1.0",
		"@lucidcms/core": "^0.12.0-alpha.1",
		"@lucidcms/node-adapter": "^1.0.1",
		"astro": "^6.0.0"
	},
	"peerDependenciesMeta": {
		"@lucidcms/cloudflare-adapter": {
			"optional": true
		},
		"@lucidcms/node-adapter": {
			"optional": true
		}
	},
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	},
	"license": "MIT"
}
