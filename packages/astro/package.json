{
	"name": "@lucidcms/astro",
	"version": "0.1.2",
	"private": false,
	"description": "The official Astro integration for Lucid CMS",
	"type": "module",
	"types": "./dist/index.d.mts",
	"module": "./dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./configure-lucid": {
			"types": "./dist/configure-lucid.d.mts",
			"default": "./dist/configure-lucid.mjs"
		},
		"./toolkit": {
			"types": "./toolkit.d.mts",
			"default": "./dist/toolkit.mjs"
		},
		"./admin-bar": {
			"types": "./dist/admin-bar.d.mts",
			"default": "./dist/admin-bar.mjs"
		},
		"./internal/runtime": {
			"types": "./dist/internal/runtime.d.mts",
			"default": "./dist/internal/runtime.mjs"
		},
		"./internal/admin-bar": {
			"types": "./dist/internal/admin-bar.d.mts",
			"default": "./dist/internal/admin-bar.mjs"
		},
		"./types": {
			"types": "./dist/types.d.mts",
			"default": "./dist/types.mjs"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src"
	},
	"files": [
		"dist",
		"toolkit.d.mts"
	],
	"author": "Build Lucid Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/astro"
	},
	"keywords": [
		"CMS",
		"Astro",
		"Lucid CMS",
		"Lucid",
		"Integration"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@lucidcms/runtime-cloudflare": "1.0.2",
		"@lucidcms/core": "0.15.0-alpha.0",
		"@lucidcms/runtime-node": "1.0.2",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^24.13.2",
		"astro": "^7.0.2",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"mime-types": "^3.0.2"
	},
	"peerDependencies": {
		"@lucidcms/runtime-cloudflare": "^1.0.0",
		"@lucidcms/core": "^0.15.0-alpha.0",
		"@lucidcms/runtime-node": "^1.0.0",
		"astro": "^7.0.2"
	},
	"peerDependenciesMeta": {
		"@lucidcms/runtime-cloudflare": {
			"optional": true
		},
		"@lucidcms/runtime-node": {
			"optional": true
		}
	},
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	}
}
