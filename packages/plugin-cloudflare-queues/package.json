{
	"name": "@lucidcms/plugin-cloudflare-queues",
	"version": "1.0.0",
	"description": "The official Cloudflare Queues plugin for Lucid CMS",
	"type": "module",
	"types": "./dist/index.d.mts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src"
	},
	"files": [
		"dist"
	],
	"author": "Lucid",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/plugin-cloudflare-queues"
	},
	"keywords": [
		"CMS",
		"Lucid CMS",
		"Lucid",
		"Cloudflare",
		"Queues",
		"Plugin"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@lucidcms/cloudflare-adapter": "1.1.0",
		"@lucidcms/core": "0.12.0-alpha.1",
		"@types/node": "^24.10.4",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3",
		"@cloudflare/workers-types": "^4.20260301.1"
	},
	"peerDependencies": {
		"@lucidcms/cloudflare-adapter": "^1.1.0",
		"@lucidcms/core": "^0.12.0-alpha.1"
	},
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	},
	"license": "MIT"
}
