{
	"compilerOptions": {
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ESNext",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"rootDir": "./src",
		"outDir": "./dist"
	},
	"exclude": ["./dist", "./node_modules", "./.turbo", "**/*.test.ts"]
}
