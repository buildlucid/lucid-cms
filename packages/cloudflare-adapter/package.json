{
	"name": "@lucidcms/cloudflare-adapter",
	"version": "1.1.0",
	"private": false,
	"description": "The official Cloudflare Worker adapter for Lucid CMS",
	"type": "module",
	"types": "./dist/index.d.mts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./env": {
			"types": "./dist/env.d.mts",
			"default": "./dist/env.mjs"
		},
		"./cli": {
			"types": "./dist/cli.d.mts",
			"default": "./dist/cli.mjs"
		},
		"./runtime": {
			"types": "./dist/runtime.d.mts",
			"default": "./dist/runtime.mjs"
		},
		"./types": {
			"types": "./dist/types.d.mts",
			"default": "./dist/types.mjs"
		}
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
        "check": "biome check ./src",
        "check:fix": "biome check --write ./src"
	},
	"files": ["dist"],
	"author": "Lucid",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/cloudflare-adapter"
	},
	"keywords": [
		"CMS",
		"Lucid CMS",
		"Lucid",
		"Cloudflare",
		"Worker",
		"Environment Adapter"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@lucidcms/config": "*",
		"@lucidcms/core": "*",
		"@types/node": "^24.10.4",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.9",
		"rolldown": "^1.0.0-rc.6",
		"wrangler": "^4.69.0"
	},
	"peerDependencies": {
		"@lucidcms/core": "^0.12.0-alpha.1",
		"hono": "^4.12.3",
        "hono-openapi": "^1.2.0"
	},
    "volta": {
        "node": "24.11.1"
    },
    "engines": {
        "node": "^24.0.0"
    },
	"license": "MIT"
}
