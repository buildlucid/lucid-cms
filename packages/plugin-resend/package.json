{
	"name": "@lucidcms/plugin-resend",
	"version": "1.1.2",
	"description": "The official Resend plugin for Lucid CMS",
	"type": "module",
	"types": "./dist/index.d.ts",
	"module": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.ts"
		},
		"./translations": "./translations"
	},
	"scripts": {
		"build": "tsc && tsdown",
		"dev": "tsdown --watch",
		"format": "biome format ./src",
		"format:fix": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"check": "biome check ./src",
		"check:fix": "biome check --write ./src"
	},
	"files": [
		"dist/**",
		"translations"
	],
	"author": "Build Lucid Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buildlucid/lucid-cms.git",
		"directory": "packages/plugin-resend"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@lucidcms/core": "0.15.0-alpha.0",
		"@types/node": "^24.13.2",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@lucidcms/core": "^0.15.0-alpha.0"
	},
	"dependencies": {
		"hono": "^4.12.27",
		"@hono/standard-validator": "^0.2.2",
		"hono-openapi": "^1.3.0",
		"svix": "^1.96.0"
	},
	"volta": {
		"node": "24.11.1"
	},
	"engines": {
		"node": "^24.0.0"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	}
}
